ANTHROPIC_API_KEY=your_api_key_here
PORT=3001
ANTHROPIC_MODEL=claude-sonnet-5

# Optional: powers real recipe photos on recipe cards. Get a free key at
# https://www.pexels.com/api/ — without it, recipe cards fall back to an
# illustrated icon instead of a photo.
PEXELS_API_KEY=your_pexels_api_key_here
